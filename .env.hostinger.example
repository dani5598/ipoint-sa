# ============================================================
#  ipointapple — Hostinger production environment
#  Copy this file to ".env" on the server and fill in the DB_* values
#  from hPanel → Databases → MySQL. Everything else is ready to go.
# ============================================================

APP_NAME="ipointapple"
APP_ENV=production
# Paste the APP_KEY separately provided to you (base64:...), or run `php artisan key:generate` if you get SSH.
# Never commit a real key to git.
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# Log as little as possible in production
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

# --- Database: create this in hPanel → Databases → MySQL, then paste the values ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=REPLACE_WITH_HOSTINGER_DB_NAME
DB_USERNAME=REPLACE_WITH_HOSTINGER_DB_USER
DB_PASSWORD=REPLACE_WITH_HOSTINGER_DB_PASSWORD

# File-based session/cache/queue need no extra services — safest on shared hosting
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=file
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=local

BROADCAST_CONNECTION=log

# Mail — set to Hostinger SMTP (hPanel → Emails) if you want booking/order emails to send.
MAIL_MAILER=log
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS="no-reply@your-domain.com"
MAIL_FROM_NAME="${APP_NAME}"

# Optional: HERE Maps key powers the live order-tracking map. Leave blank to use the fallback UI.
HERE_API_KEY=

# --- No-SSH one-time setup runner (routes/web.php → /__setup/<token>) ---
# DISABLED while blank. To create the DB tables from a browser:
#   1. Put a long random string here (e.g. `openssl rand -hex 24` or any 40+ random chars).
#   2. Visit  https://your-domain.com/__setup/<that-string>?seed=1   ONCE.
#   3. Blank this back out (SETUP_TOKEN=) so the route is disabled again.
SETUP_TOKEN=

VITE_APP_NAME="${APP_NAME}"
